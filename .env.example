# Django environment configuration
DJANGO_SECRET_KEY=replace-with-your-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL configuration
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=finance_cookie
DJANGO_DB_USER=your_db_user
DJANGO_DB_PASSWORD=your_db_password
DJANGO_DB_HOST=remote-db-host.example.com
DJANGO_DB_PORT=5432

# Expo frontend
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://127.0.0.1:19006
